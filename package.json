  "homepage": "https://github.com/falkoschumann/muspellheim-shared-js",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/lib.cjs",
