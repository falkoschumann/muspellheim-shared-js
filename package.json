        "default": "./dist/lib.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "watch": "vitest watch"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@softarc/sheriff-core": "0.19.6",
    "@vitest/coverage-istanbul": "4.1.8",
    "eslint": "10.5.0",
    "eslint-plugin-headers": "1.3.4",
    "globals": "17.6.0",
    "prettier": "3.8.4",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.8"
  }
}
